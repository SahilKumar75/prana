# ── Backend .env template ──────────────────────────────────────────────────────
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Supabase PostgreSQL (Session Pooler — port 5432 or 6543)
# From: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=jdbc:postgresql://db.<YOUR_REF>.supabase.co:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=<YOUR_SUPABASE_DB_PASSWORD>

# Groq API Key — https://console.groq.com
GROQ_API_KEY=gsk_...

# Comma-separated frontend URL(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://prana.vercel.app

# JPA DDL mode: validate (prod) | update (dev)
JPA_DDL_AUTO=validate
